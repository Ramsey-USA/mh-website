# Copy to .env.r2.local and keep it private.
# This file is gitignored by the existing .env*.local rule.

# Cloudflare account used for Wrangler R2 publish scripts.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Use a dedicated, least-privilege token for R2 publish workflows.
# Recommended scopes:
# - Developer Platform -> Workers R2 Storage -> Edit
# - Developer Platform -> Workers Scripts -> Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token