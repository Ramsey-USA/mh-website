set -e

echo "🔍 Pre-commit: running quality checks..."

# Run lint-staged (eslint + prettier on staged files)
echo "\n✨ Linting staged files..."
npx lint-staged

# TypeScript type-check
echo "\n📘 Type checking..."
npm run --silent type-check

# Check for common issues
echo "\n🧹 Checking for code quality issues..."

# Check for console.log in staged files (warning only)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '^scripts/' || true)
if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | xargs grep -n "console\.log" 2>/dev/null; then
    echo "⚠️  Warning: Found console.log statements. Consider using logger instead."
  fi
fi

# Check for large files
for file in $(git diff --cached --name-only); do
  # Skip package lock files, generated files, and large template files with inline assets
  case "$file" in
    package-lock.json|yarn.lock|pnpm-lock.yaml|.next/*|node_modules/*|documents/manuals/*.html|public/docs/*.pdf)
      continue
      ;;
  esac
  
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" 2>/dev/null || echo "0")
    if [ "$size" -gt 500000 ]; then
      echo "❌ Error: $file is larger than 500KB. Please optimize before committing."
      exit 1
    fi
  fi
done

echo "✅ Pre-commit: all checks passed!"
