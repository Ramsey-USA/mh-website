{
  "version": "0.2",
  "language": "en,es",
  "ignorePaths": [
    "node_modules/**",
    "firebase/functions/node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "*.min.js",
    "*.min.css",
    "coverage/**",
    "lighthouse-results/**",
    ".next/**",
    "out/**"
  ],
  "languageSettings": [
    {
      "languageId": "markdown",
      "ignoreRegExpList": [
        "/```[\\s\\S]*?```/g",
        "/`[^`]*`/g",
        "/\\$\\$[\\s\\S]*?\\$\\$/g",
        "/\\$[^$]*\\$/g"
      ]
    },
    {
      "languageId": "shellscript,bash",
      "ignoreRegExpList": ["/\\b(gsub|awk|sed|grep|printf|substr)\\b/g"]
    }
  ],
  "dictionaryDefinitions": [
    {
      "name": "technical-words",
      "path": "./config/cspell/project-words.txt",
      "addWords": true
    },
    {
      "name": "technical-additions",
      "path": "./config/cspell/technical-additions.txt",
      "addWords": true
    },
    {
      "name": "safety-industry-words",
      "path": "./config/cspell/safety-industry-words.txt",
      "addWords": true
    },
    {
      "name": "names-and-places-words",
      "path": "./config/cspell/names-and-places-words.txt",
      "addWords": true
    },
    {
      "name": "spanish-custom-words",
      "path": "./config/cspell/spanish-custom-words.txt",
      "addWords": true
    },
    {
      "name": "es-es",
      "path": "./node_modules/@cspell/dict-es-es/Spanish.trie.gz"
    }
  ],
  "dictionaries": [
    "es-es",
    "technical-words",
    "technical-additions",
    "safety-industry-words",
    "names-and-places-words",
    "spanish-custom-words"
  ],
  "words": [],
  "ignoreWords": [],
  "import": []
}
