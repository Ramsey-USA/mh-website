{
  "name": "mh-monorepo",
  "version": "7.1.0",
  "description": "MH Construction monorepo — public website + operations dashboard",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mhc/website dev",
    "dev:inspect": "pnpm --filter @mhc/website dev:inspect",
    "dev:dashboard": "pnpm --filter @mhc/dashboard dev",
    "build": "pnpm --filter @mhc/website build",
    "deploy": "pnpm --filter @mhc/website run deploy",
    "build:dashboard": "pnpm --filter @mhc/dashboard build",
    "build:all": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter @mhc/dashboard lint && pnpm --filter @mhc/website lint",
    "lint:fix": "pnpm --filter @mhc/dashboard lint:fix && pnpm --filter @mhc/website lint:fix",
    "type-check": "pnpm --filter './apps/*' type-check",
    "test": "pnpm --filter @mhc/website test",
    "test:shared": "pnpm --filter @mhc/shared test",
    "test:all": "pnpm -r --if-present run test",
    "nav:contract:check": "pnpm --filter @mhc/website nav:contract:check",
    "chat": "pnpm --filter @mhc/website chat",
    "chat:smoke": "pnpm --filter @mhc/website chat:smoke",
    "smoke:routes": "pnpm --filter @mhc/website smoke:routes",
    "test:dashboard": "pnpm --filter @mhc/dashboard test",
    "test:ci": "pnpm --filter @mhc/website test:ci",
    "test:ci:dashboard": "pnpm --filter @mhc/dashboard test:ci",
    "test:ci:all": "pnpm --filter './apps/*' test:ci",
    "cleanup:ast-safe": "node scripts/codemods/ast-safe-cleanup.js",
    "cleanup:ast-safe:write": "node scripts/codemods/ast-safe-cleanup.js --write",
    "format": "prettier --write --cache --cache-location .prettier-cache .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "security:check": "node scripts/validation/security-audit-gate.mjs --prod --level moderate",
    "security:check:prod": "node scripts/validation/security-audit-gate.mjs --prod --level high",
    "security:check:strict": "node scripts/validation/security-audit-gate.mjs --prod --level low",
    "audit:ci": "pnpm run security:check:prod",
    "lint:markdown": "INCLUDE_DOC_GUARDRAILS=1 bash scripts/markdown/run-markdownlint.sh",
    "lint:markdown:fix": "INCLUDE_DOC_GUARDRAILS=1 bash scripts/markdown/run-markdownlint.sh --fix",
    "lint:brand": "bash apps/website/scripts/brand-lint.sh",
    "lint:brand:ci": "BRAND_LINT_CHANGED_ONLY=true BRAND_LINT_BASE_SHA=${BASE_SHA:-} bash apps/website/scripts/brand-lint.sh",
    "docs:sync": "bash scripts/docs/sync-to-app.sh",
    "docs:sync:check": "bash scripts/docs/check-sync.sh",
    "scripts:sync": "bash scripts/wrappers/sync-from-website.sh",
    "scripts:sync:check": "bash scripts/wrappers/sync-from-website.sh --check",
    "app:mirrors:sync": "bash scripts/duplicates/sync-app-mirrors.sh",
    "app:mirrors:sync:check": "bash scripts/duplicates/sync-app-mirrors.sh --check",
    "migrations:sync": "bash scripts/migrations/sync-from-root.sh",
    "migrations:sync:check": "bash scripts/migrations/sync-from-root.sh --check",
    "docs:preflight:pdf-output": "pnpm --filter @mhc/website run docs:preflight:pdf-output",
    "docs:clean:legacy-output": "bash scripts/docs/clean-stale-pdf-output.sh",
    "docs:guardrails:contracts": "bash scripts/validation/check-branding-doc-contracts.sh",
    "docs:stack:congruency:check": "node scripts/validation/check-doc-stack-congruency.mjs",
    "guard:generated-artifacts": "bash scripts/validation/check-no-generated-artifacts.sh",
    "docs:extract": "node documents/scripts/extract.mjs",
    "docs:guardrails:check": "pnpm --filter @mhc/website docs:guardrails:check",
    "docs:guardrails:typography:check": "pnpm --filter @mhc/website docs:guardrails:typography:check",
    "docs:guardrails:manual-congruence": "node scripts/validation/check-manual-template-congruence.mjs",
    "docs:bundle:downloads": "pnpm --filter @mhc/website run docs:bundle:downloads",
    "font-system:check": "bash scripts/validation/check-font-system-usage.sh",
    "icons:forms-manuals:check": "pnpm --filter @mhc/website icons:forms-manuals:check",
    "terminology:guardrails:check": "pnpm --filter @mhc/website terminology:guardrails:check",
    "docs:audit:mish-overrun": "pnpm --filter @mhc/website docs:audit:mish-overrun",
    "docs:extract-word": "node documents/scripts/extract-word.mjs",
    "prepare": "node -e \"const {spawnSync}=require('node:child_process'); const result=spawnSync('git',['rev-parse','--is-inside-work-tree'],{stdio:'ignore'}); if (process.env.CI || result.status !== 0) process.exit(0)\" && husky"
  },
  "keywords": [
    "construction",
    "nextjs",
    "cloudflare",
    "veteran-owned",
    "typescript"
  ],
  "author": "MH Construction Development Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@cspell/dict-es-es": "^3.0.8",
    "@napi-rs/canvas": "^1.0.2",
    "@next/eslint-plugin-next": "^16.2.10",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "chalk": "^5.6.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "mammoth": "^1.12.0",
    "prettier": "^3.9.5",
    "puppeteer": "^25.3.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.2"
  },
  "overrides": {
    "tar": "7.5.11",
    "cookie": "0.7.2",
    "flatted": ">=3.4.2",
    "undici": ">=7.24.0",
    "yauzl": ">=3.2.1",
    "glob": ">=11.0.0",
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3",
    "fast-xml-parser": "^5.7.0",
    "uuid": "^14.0.0",
    "basic-ftp": ">=5.3.1",
    "ip-address": ">=10.1.1",
    "@opennextjs/aws": "4.0.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "postcss": ">=8.5.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx eslint --fix --cache --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
