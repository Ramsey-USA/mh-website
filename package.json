{
  "name": "mh-monorepo",
  "version": "7.1.0",
  "description": "MH Construction monorepo — public website + operations dashboard",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mhc/website dev",
    "dev:inspect": "pnpm --filter @mhc/website dev:inspect",
    "dev:dashboard": "pnpm --filter @mhc/dashboard dev",
    "build": "pnpm --filter @mhc/website build",
    "deploy": "pnpm --filter @mhc/website run deploy",
    "build:dashboard": "pnpm --filter @mhc/dashboard build",
    "build:all": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter @mhc/dashboard lint && pnpm --filter @mhc/website lint",
    "lint:fix": "pnpm --filter @mhc/dashboard lint:fix && pnpm --filter @mhc/website lint:fix",
    "type-check": "pnpm --filter './apps/*' type-check",
    "test": "pnpm --filter @mhc/website test",
    "smoke:routes": "pnpm --filter @mhc/website smoke:routes",
    "test:dashboard": "pnpm --filter @mhc/dashboard test",
    "test:ci": "pnpm --filter @mhc/website test:ci",
    "test:ci:dashboard": "pnpm --filter @mhc/dashboard test:ci",
    "test:ci:all": "pnpm --filter './apps/*' test:ci",
    "cleanup:ast-safe": "node scripts/codemods/ast-safe-cleanup.js",
    "cleanup:ast-safe:write": "node scripts/codemods/ast-safe-cleanup.js --write",
    "format": "prettier --write --cache --cache-location .prettier-cache .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "security:check:prod": "pnpm audit --prod --audit-level high",
    "audit:ci": "pnpm run security:check:prod",
    "lint:markdown": "pnpm docs:sync:check && git ls-files '*.md' ':!:.github/agents/**' ':!:public/images/qr-codes/README.md' ':!:apps/website/public/images/qr-codes/README.md' ':!:apps/website/docs/**' | xargs -r markdownlint-cli2 --config .markdownlint-cli2.jsonc --ignore-path .markdownlintignore --no-globs",
    "lint:brand": "bash apps/website/scripts/brand-lint.sh",
    "lint:brand:ci": "BRAND_LINT_CHANGED_ONLY=true BRAND_LINT_BASE_SHA=${BASE_SHA:-} bash apps/website/scripts/brand-lint.sh",
    "docs:sync": "bash scripts/docs/sync-to-app.sh",
    "docs:sync:check": "bash scripts/docs/check-sync.sh",
    "docs:extract": "node apps/website/documents/scripts/extract.mjs",
    "prepare": "node -e \"const {spawnSync}=require('node:child_process'); const result=spawnSync('git',['rev-parse','--is-inside-work-tree'],{stdio:'ignore'}); if (process.env.CI || result.status !== 0) process.exit(0)\" && husky"
  },
  "keywords": [
    "construction",
    "nextjs",
    "cloudflare",
    "veteran-owned",
    "typescript"
  ],
  "author": "MH Construction Development Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-es-es": "^3.0.8",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": ">=5.3.1",
      "fast-xml-parser": "^5.7.0",
      "ip-address": ">=10.1.1",
      "next": "16.2.6",
      "uuid": "^14.0.0",
      "postcss": ">=8.5.10"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@react-email/render"
      ]
    }
  },
  "overrides": {
    "tar": "7.5.11",
    "cookie": "0.7.2",
    "flatted": ">=3.4.2",
    "undici": ">=7.24.0",
    "yauzl": ">=3.2.1",
    "glob": ">=11.0.0",
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3",
    "fast-xml-parser": "^5.7.0",
    "uuid": "^14.0.0",
    "basic-ftp": ">=5.3.1",
    "ip-address": ">=10.1.1",
    "next": "16.2.6",
    "postcss": ">=8.5.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx eslint --fix --cache --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
