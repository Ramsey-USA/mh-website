{
  "name": "mh-website",
  "version": "4.0.0",
  "description": "Veteran-owned construction website for MH Construction - Honest Communication, Proven Craftsmanship",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "build:next": "next build",
    "build:fast": "NODE_ENV=production SKIP_LINT=true next build",
    "build:profile": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "ci:gate": "npm run type-check && npm run lint && npm run format:check && npm run test:ci && npm run audit:ci && npm run build",
    "smoke:safety": "node scripts/validation/smoke-safety-system.js",
    "test:pwa": "node scripts/test-pwa.js",
    "test:performance": "node scripts/test-basic-performance.js",
    "lighthouse:guide": "node scripts/lighthouse-guide.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pages:dev": "npm run dev",
    "bundle:size": "npm run build && du -sh .next/static/chunks/*.js | sort -hr | head -10",
    "clean": "bash scripts/cleanup/cleanup.sh",
    "maintenance": "npm run clean",
    "lint:markdown": "markdownlint-cli2 --config .markdownlint-cli2.jsonc --ignore-path .markdownlintignore \"**/*.md\"",
    "lint:markdown:fix": "markdownlint-cli2 --fix --config .markdownlint-cli2.jsonc --ignore-path .markdownlintignore \"**/*.md\"",
    "cspell:check": "npx cspell \"**/*.{md,js,ts,tsx,json}\" --no-progress --show-context",
    "docs:extract": "node documents/scripts/extract.mjs",
    "docs:extract-word": "node documents/scripts/extract-word.mjs",
    "docs:generate": "node documents/scripts/generate.mjs",
    "docs:generate:cover": "node documents/scripts/generate.mjs --template cover",
    "docs:generate:spine": "node documents/scripts/generate.mjs --template spine",
    "docs:generate:tabs": "node documents/scripts/generate.mjs --template tabs",
    "docs:generate:sections": "node documents/scripts/generate.mjs --template sections",
    "docs:generate:toolbox": "node documents/scripts/generate.mjs --template toolbox-talk",
    "docs:merge": "node documents/scripts/merge.mjs",
    "docs:merge:digital": "node documents/scripts/merge.mjs --no-tabs",
    "docs:publish": "node -e \"const{mkdirSync,cpSync}=require('fs');mkdirSync('public/docs/sections',{recursive:true});mkdirSync('public/docs/forms',{recursive:true});cpSync('documents/output','public/docs',{recursive:true});console.log('✓ PDFs published to public/docs/')\"",
    "docs:all": "npm run docs:generate && npm run docs:merge && npm run docs:merge:digital && npm run docs:publish",
    "qr:generate": "node scripts/generate-qr-codes.js",
    "qr:test": "node scripts/test-qr-codes.js",
    "qr:check": "bash scripts/check-qr-codes.sh",
    "optimize:images": "node scripts/optimization/optimize-images.js",
    "optimize:videos": "node scripts/optimization/optimize-videos.js",
    "audit:images": "node scripts/optimization/audit-images.js",
    "quality:check": "bash scripts/utilities/cleanup-check.sh",
    "deps:check": "npx depcheck --ignores='@types/*,eslint-*,prettier,husky,@commitlint/*,postcss,autoprefixer,jest-environment-jsdom,@opennextjs/cloudflare,chalk'",
    "deps:update": "npm outdated",
    "deps:clean": "npm prune && npm dedupe",
    "prepare": "node -e \"if (process.env.CI) process.exit(0)\" && husky"
  },
  "keywords": [
    "construction",
    "nextjs",
    "cloudflare",
    "veteran-owned",
    "typescript"
  ],
  "author": "MH Construction Development Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "next": "^15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/swc-linux-x64-gnu": "^16.1.6",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "chalk": "^5.6.2",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.12",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsqr": "^1.4.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.3.3",
    "mammoth": "^1.12.0",
    "markdownlint-cli2": "^0.21.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "wrangler": "^4.77.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "tar": "7.5.11",
    "cookie": "0.7.2",
    "flatted": ">=3.4.2",
    "undici": ">=7.24.0",
    "yauzl": ">=3.2.1",
    "glob": ">=11.0.0",
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3",
    "fast-xml-parser": "^5.5.9"
  }
}
