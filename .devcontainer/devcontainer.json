{
  "name": "mh-website",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  // Fix 3: Require a 4-core/16 GB machine so the stack never hits the OOM killer.
  // GitHub Codespaces will provision the next available tier that meets these specs.
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      // Fix 6: Heavy background-process extensions moved to recommendations.
      // They are still installable via the Extensions panel but won't auto-start
      // on every Codespace and won't consume memory until explicitly enabled.
      // See "recommendations" block below.
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "csstools.postcss",
        "github.copilot",
        "github.copilot-chat",
        "orta.vscode-jest",
        "mikestead.dotenv",
        "streetsidesoftware.code-spell-checker",
        "davidanson.vscode-markdownlint",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "js/ts.preferences.importModuleSpecifier": "relative",
        "files.associations": {
          "*.css": "tailwindcss"
        },
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.next/**": true,
          "**/.wrangler/**": true,
          "**/public/images/**": true,
          "**/.pnpm-store/**": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/.next": true,
          "**/.wrangler": true,
          "**/pnpm-lock.yaml": true,
          "**/public/images": true,
          "**/.pnpm-store": true
        },
        // Fix 1: Halved from 3072 → 1536 MB. IntelliSense is fully functional
        // at 1.5 GB; 3 GB was consuming nearly half the available RAM on the
        // default 8 GB machine and triggering the Linux OOM killer.
        "typescript.tsserver.maxTsServerMemory": 1536,
        "jest.autoRun": "off"
      }
    }
  },
  // Fix 2: --config.optional=false skips heavy optional deps (puppeteer/Chromium,
  // tesseract.js, pdfjs-dist, lighthouse, sharp, @napi-rs/canvas, etc.) that are
  // only needed by CI image-optimisation scripts and aren't required for daily dev.
  // This reduces node_modules by ~2–3 GB and eliminates creation-time OOM risk.
  "postCreateCommand": "corepack enable pnpm && pnpm install --frozen-lockfile --config.optional=false",
  "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
  // Fix 4: "stopContainer" preserves the container filesystem on idle timeout so
  // the Codespace resumes cleanly without re-running postCreateCommand.
  // The alternative ("none") destroys state; the default is also "stopContainer"
  // but setting it explicitly prevents accidental org-policy overrides.
  "shutdownAction": "stopContainer",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Dev Server",
      "onAutoForward": "openPreview"
    }
  },
  "remoteUser": "node"
}
