{
  "name": "@mhc/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript library for MH Construction monorepo",
  "scripts": {
    "test": "pnpm --filter @mhc/website exec jest --config ../../packages/shared/jest.config.js",
    "test:ci": "pnpm --filter @mhc/website exec jest --config ../../packages/shared/jest.config.js --ci --runInBand",
    "test:watch": "pnpm --filter @mhc/website exec jest --config ../../packages/shared/jest.config.js --watch",
    "test:coverage": "pnpm --filter @mhc/website exec jest --config ../../packages/shared/jest.config.js --coverage"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.20.2",
    "@sentry/browser": "^10.65.0",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "toucan-js": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^6.0.3"
  }
}
