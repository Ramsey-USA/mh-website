    },
    {
      "id": "section-49",
      "number": 49,
      "numberStr": "49",
      "key": "MISH_49",
      "title": "Incident Investigation Root Cause Analysis",
      "slug": "incident-investigation-root-cause-analysis",
      "previewHtml": "<h1>1.0 PURPOSE</h1><p><strong>1.1 </strong>All incidents, near-misses, and property damage events must be investigated to identify root causes and prevent recurrence.</p><p><strong>1.2 </strong>Investigation is not about assigning blame — it is about identifying system failures and implementing corrective actions.</p>"
    },
    {
      "id": "section-50",
      "number": 50,
      "numberStr": "50",
      "key": "MISH_50",
      "title": "Return to Work Program",
      "slug": "return-to-work-program",
      "previewHtml": "<h1>1.0 PURPOSE</h1><p><strong>1.1 </strong>MH Construction is committed to returning injured employees to productive work as quickly and safely as possible.</p><p><strong>1.2 </strong>A formal Return-to-Work (RTW) program reduces workers compensation costs, maintains employee morale, and demonstrates MHC's commitment to its workforce.</p>"
    }
