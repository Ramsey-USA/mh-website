<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MH Construction, Inc. — Safety Manual Cover</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      @page {
        size: letter portrait;
        margin: 0;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        width: 8.5in;
        height: 11in;
        font-family: "Helvetica Neue", Arial, sans-serif;
        background: white;
        overflow: hidden;
      }

      /* ── Full-bleed cover ──────────────────────────────── */
      .cover {
        width: 8.5in;
        height: 11in;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
      }

      /* Top band – deep brand green */
      .cover-top {
        background: #1e392c;
        height: 0.55in;
        width: 100%;
        display: flex;
        align-items: center;
        padding: 0 0.5in;
      }
      .cover-top-text {
        color: #bd9264;
        font-size: 8.5pt;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      /* Main hero area */
      .cover-hero {
        flex: 1;
        background: linear-gradient(
          160deg,
          #1e392c 0%,
          #386851 50%,
          #628f79 100%
        );
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.3in 0.6in;
        position: relative;
      }

      /* Diagonal texture overlay */
      .cover-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          -45deg,
          rgba(255, 255, 255, 0.015) 0px,
          rgba(255, 255, 255, 0.015) 1px,
          transparent 1px,
          transparent 8px
        );
      }

      /* White logo panel */
      .cover-logo-wrap {
        background: white;
        padding: 0.2in 0.3in;
        border-radius: 4pt;
        display: inline-block;
        margin-bottom: 0.35in;
        position: relative;
        z-index: 1;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      }
      .cover-logo {
        height: 1.35in;
        width: auto;
        display: block;
      }

      .cover-rule {
        width: 2.5in;
        height: 2.5pt;
        background: linear-gradient(
          90deg,
          transparent,
          #bd9264,
          #a87948,
          #bd9264,
          transparent
        );
        border-radius: 2pt;
        margin-bottom: 0.2in;
        position: relative;
        z-index: 1;
      }

      .cover-document-label {
        color: #d9bd93;
        font-size: 10pt;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        margin-bottom: 0.08in;
        position: relative;
        z-index: 1;
      }

      .cover-title {
        color: #ffffff;
        font-size: 38pt;
        font-weight: 900;
        text-align: center;
        line-height: 1.05;
        margin: 0 0 0.08in;
        letter-spacing: -0.01em;
        position: relative;
        z-index: 1;
      }

      .cover-subtitle {
        color: #bd9264;
        font-size: 11pt;
        font-weight: 500;
        text-align: center;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.3in;
        position: relative;
        z-index: 1;
      }

      .cover-rule-bottom {
        width: 1.5in;
        height: 1.5pt;
        background: rgba(189, 146, 100, 0.5);
        border-radius: 1pt;
        margin-bottom: 0.25in;
        position: relative;
        z-index: 1;
      }

      /* Veteran badge */
      .cover-veteran {
        display: inline-flex;
        align-items: center;
        gap: 7pt;
        background: rgba(168, 121, 72, 0.25);
        border: 1pt solid rgba(168, 121, 72, 0.6);
        border-radius: 3pt;
        padding: 5pt 14pt;
        color: #d9bd93;
        font-size: 8.5pt;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
        margin-bottom: 0.15in;
      }
      .cover-veteran::before {
        content: "★";
        color: #bd9264;
        font-size: 10pt;
      }
      .cover-veteran::after {
        content: "★";
        color: #bd9264;
        font-size: 10pt;
      }

      /* Single-line bottom band */
      .cover-bottom {
        background: #12231b;
        padding: 0 0.45in;
        height: 0.65in;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.2in;
      }
      .cover-bottom-info {
        color: rgba(255, 255, 255, 0.85);
        font-size: 8pt;
        white-space: nowrap;
        flex-shrink: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .cover-bottom-info .sep {
        color: #8a6b49;
        margin: 0 5pt;
      }
      .cover-bottom-right {
        display: flex;
        align-items: center;
        gap: 0.2in;
        flex-shrink: 0;
      }
      .cover-licenses {
        text-align: right;
        font-size: 7pt;
        color: #8a6b49;
        white-space: nowrap;
        line-height: 1.6;
      }
      .cover-licenses .rev {
        color: #bd9264;
        font-weight: 600;
      }
      .cover-agc-logo {
        height: 0.38in;
        width: auto;
        display: block;
        flex-shrink: 0;
      }

      .cover-qr-code {
        height: 0.5in;
        width: auto;
        display: block;
        flex-shrink: 0;
        border: 1pt solid #8a6b49;
        padding: 2pt;
        background: white;
        border-radius: 3pt;
      }

      /* Bronze accent bar on left edge — binder side */
      .cover-spine-accent {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 0.18in;
        background: linear-gradient(180deg, #a87948, #bd9264, #a87948);
        z-index: 10;
      }
    </style>
  </head>
  <body>
    <div class="cover">
      <!-- Left edge accent bar (decorative, binder side) -->
      <div class="cover-spine-accent"></div>

      <!-- Top band -->
      <div class="cover-top">
        <span class="cover-top-text"
          >MH Construction, Inc. &nbsp;·&nbsp; Founded 2010, Veteran-Owned Since
          January 2025 &nbsp;·&nbsp; Pasco, WA 99301</span
        >
      </div>

      <!-- Hero -->
      <div class="cover-hero">
        <div class="cover-logo-wrap">
          <img
            class="cover-logo"
            src="file:///workspaces/mh-website/assets/logo-color.png"
            alt="MH Construction"
          />
        </div>
        <div class="cover-rule"></div>
        <div class="cover-document-label">Company Safety Program</div>
        <div class="cover-title">Safety<br />Manual</div>
        <div class="cover-subtitle">Accident · Injury · Safety · Health</div>
        <div class="cover-rule-bottom"></div>
        <div class="cover-veteran">
          Founded 2010, Veteran-Owned Since January 2025
        </div>
      </div>

      <!-- Single-line bottom band -->
      <div class="cover-bottom">
        <div class="cover-bottom-info">
          <strong>MH Construction, Inc.</strong><span class="sep">·</span>3111
          N. Capitol Ave., Pasco, WA 99301<span class="sep">·</span>(509)
          308-6489<span class="sep">·</span>www.mhc-gc.com
        </div>
        <div class="cover-bottom-right">
          <div class="cover-licenses">
            WA Lic: MHCONCI907R7 &nbsp;·&nbsp; OR Lic: 765043-99 &nbsp;·&nbsp;
            ID Lic: RCE-49250<br />
            <span class="rev">Revision 2026</span>
          </div>
          <img
            class="cover-qr-code"
            src="file:///workspaces/mh-website/assets/qr-safety-dashboard-color.png"
            alt="Safety Dashboard QR Code"
          />
          <img
            class="cover-agc-logo"
            src="file:///workspaces/mh-website/assets/nwagc-logo.png"
            alt="AGC Member"
          />
        </div>
      </div>
    </div>
  </body>
</html>
