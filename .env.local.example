# ⚠️ SECURITY WARNING: NEVER COMMIT .env.local TO GIT!
# This file contains sensitive credentials and MUST remain local only.
# The .gitignore is configured to exclude .env.local files.

# Environment Configuration Template - CLOUDFLARE WORKERS
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your actual development values
# 3. Verify it's gitignored: git status (should NOT appear)
# 4. For production: Use Cloudflare Workers secrets (wrangler secret put)

# ==============================================================================
# SITE CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_SITE_URL=https://www.mhc-gc.com
NEXT_PUBLIC_SITE_NAME=MH Construction

# ==============================================================================
# CLOUDFLARE CONFIGURATION
# ==============================================================================
# Get these values from Cloudflare Dashboard -> Workers & Pages

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ==============================================================================
# CLOUDFLARE KV (Key-Value Store)
# ==============================================================================
# Create KV namespaces in Cloudflare Dashboard -> Workers & Pages -> KV

KV_NAMESPACE_ID=your_kv_namespace_id
KV_PREVIEW_NAMESPACE_ID=your_preview_kv_namespace_id

# ==============================================================================
# CLOUDFLARE D1 (SQL Database) - Optional
# ==============================================================================
# Create D1 database: wrangler d1 create mh-construction-db

D1_DATABASE_ID=your_d1_database_id

# ==============================================================================
# CLOUDFLARE R2 (Object Storage) - Optional
# ==============================================================================
# Create R2 bucket in Cloudflare Dashboard -> R2

R2_BUCKET_NAME=mh-construction-assets
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# ==============================================================================
# EXTERNAL SERVICES
# ==============================================================================

# Email Service - Resend (https://resend.com)
# ⚠️ CRITICAL: This API key provides full access to email sending
# ⚠️ NEVER commit the actual key - use this template format only
# ⚠️ Rotate keys every 90 days per security policy
# 
# Setup Instructions:
# 1. Sign up at https://resend.com
# 2. Verify your domain (office@mhc-gc.com requires mhc-gc.com domain verification)
# 3. Create API key at https://resend.com/api-keys
# 4. Replace placeholder below with your actual key
# 5. For production: Use Cloudflare Workers secrets, NOT .env file
# 
# NOTE: All forms send to BOTH office@mhc-gc.com AND matt@mhc-gc.com
# - office@mhc-gc.com is the public/displayed email address
# - matt@mhc-gc.com receives copies but is not displayed publicly
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Replace with your actual key
EMAIL_FROM=noreply@mhc-gc.com

# SMS Service - Twilio (https://www.twilio.com) — OPTIONAL
# ⚠️ SMS notifications degrade gracefully when not configured
# ⚠️ Used for admin alerts only, not customer-facing
#
# Setup Instructions:
# 1. Sign up at https://www.twilio.com
# 2. Get Account SID and Auth Token from Console dashboard
# 3. Purchase or use a verified phone number
# 4. For production: Use Cloudflare Workers secrets
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15093086489

# Analytics (Optional but Recommended)
# Google Analytics 4 - Track user behavior and website performance
# Setup Instructions:
# 1. Create Google Analytics 4 property at https://analytics.google.com
# 2. Get your Measurement ID (starts with G-)
# 3. Add the ID below
# 4. Analytics will automatically track:
#    - Page views, sessions, user journeys
#    - Device info, browser, OS, screen resolution
#    - Geographic data (timezone, language, country inference)
#    - Traffic sources (referrer, UTM parameters, social/organic)
#    - Performance metrics (Web Vitals: LCP, FID, CLS)
#    - Custom events (clicks, form submissions, conversions)
# Leave empty to use localStorage-only tracking (no external service)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================================================
# SAFETY HUB – FIELD STAFF AUTHENTICATION
# ==============================================================================
# Shared passcode for Superintendents to access the /safety hub.
# Use a strong, memorable phrase. Rotate per project season.
# For production: Use Cloudflare Workers secrets (wrangler secret put FIELD_STAFF_PASSWORD)
FIELD_STAFF_PASSWORD=your-field-passcode-here

# ==============================================================================
# CLOUDFLARE TURNSTILE (Bot challenge for public forms)
# ==============================================================================
# Get both keys from Cloudflare Dashboard -> Turnstile -> Add widget
# NEXT_PUBLIC_ prefix makes the site key available in the browser
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000000000000000000000
# Secret key must NEVER be exposed to the client — server-side only
# For production: Use Cloudflare Workers secrets (wrangler secret put TURNSTILE_SECRET_KEY)
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# ==============================================================================
# DEVELOPMENT
# ==============================================================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
# SENTRY_DSN=your-server-side-sentry-dsn (for API routes)
