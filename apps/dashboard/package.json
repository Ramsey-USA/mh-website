{
  "name": "@mhc/dashboard",
  "version": "1.0.0",
  "description": "MH Construction Operations Hub — admin dashboard and field staff portal",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:turbo": "next dev --turbo --port 3001",
    "build": "npm run build:lowmem",
    "build:lowmem": "cross-env LOW_MEMORY_BUILD=true NODE_OPTIONS=--max-old-space-size=3072 opennextjs-cloudflare build",
    "deploy": "cross-env WRANGLER_SEND_METRICS=false opennextjs-cloudflare build && cross-env WRANGLER_SEND_METRICS=false wrangler deploy",
    "build:next": "next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "format": "prettier --write --cache --cache-location .prettier-cache .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "prebuild": "echo 'Dashboard prebuild step'"
  },
  "dependencies": {
    "@mhc/shared": "workspace:*",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/browser": "^10.50.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "next": "16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "toucan-js": "^4.1.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@next/swc-linux-x64-gnu": "16.2.4",
    "@opennextjs/cloudflare": "1.19.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@react-email/render"
      ]
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
