{
  "name": "@mhc/dashboard",
  "version": "1.0.0",
  "description": "MH Construction Operations Hub — admin dashboard and field staff portal",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:turbo": "next dev --turbo --port 3001",
    "build": "npm run build:lowmem",
    "build:lowmem": "cross-env LOW_MEMORY_BUILD=true NODE_OPTIONS=--max-old-space-size=4096 opennextjs-cloudflare build",
    "deploy": "node ../../scripts/deploy-opennext.mjs",
    "build:next": "next build",
    "start": "next start --port 3001",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --maxWorkers=2",
    "test:ci:coverage": "jest --ci --coverage --maxWorkers=2",
    "format": "prettier --write --cache --cache-location .prettier-cache .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "prebuild": "echo 'Dashboard prebuild step'"
  },
  "dependencies": {
    "@mhc/shared": "workspace:*",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@sentry/browser": "^10.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.8.0",
    "resend": "^6.14.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "toucan-js": "^4.1.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@next/swc-linux-x64-gnu": "16.2.9",
    "@opennextjs/cloudflare": "1.19.11",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
