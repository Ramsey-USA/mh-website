{
  "name": "@mhc/website",
  "version": "7.1.0",
  "description": "Veteran-owned construction website for MH Construction - Building Projects for the Client, NOT the Dollar",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:inspect": "cross-env NODE_OPTIONS=--inspect next dev",
    "dev:turbo": "next dev --turbo",
    "build": "npm run build:standard",
    "build:standard": "cross-env NODE_OPTIONS=\"--disable-warning=DEP0040\" opennextjs-cloudflare build",
    "build:lowmem": "cross-env LOW_MEMORY_BUILD=true NODE_OPTIONS=\"--disable-warning=DEP0040 --max-old-space-size=4096\" opennextjs-cloudflare build",
    "deploy": "node ../../scripts/deploy-opennext.mjs",
    "build:next": "next build",
    "build:fast": "NODE_ENV=production SKIP_LINT=true next build",
    "build:profile": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --runInBand",
    "test:ci:coverage": "jest --ci --coverage --runInBand",
    "security:check": "npm audit --audit-level=high",
    "security:check:prod": "pnpm audit --prod --audit-level high",
    "audit:ci": "npm run security:check:prod",
    "ci:gate": "npm run type-check && npm run lint && npm run format:check && npm run test:ci && npm run audit:ci && npm run build",
    "smoke:safety": "node scripts/validation/smoke-safety-system.js",
    "smoke:routes": "node scripts/validation/smoke-routes.js",
    "test:pwa": "node scripts/test-pwa.js",
    "test:performance": "node scripts/test-basic-performance.js",
    "perf:validate": "node scripts/validation/performance-gate.js",
    "perf:gate": "node scripts/validation/performance-gate.js --strict",
    "seo:routes:sync": "node scripts/validation/sync-seo-route-indexing-policy.js --write",
    "seo:routes:sync:check": "node scripts/validation/sync-seo-route-indexing-policy.js --check",
    "seo:routes:check": "node scripts/validation/check-seo-route-indexing.js",
    "check:asset-budgets": "node scripts/validation/check-public-asset-budgets.js",
    "lighthouse:guide": "node scripts/lighthouse-guide.js",
    "lighthouse:home": "npx lighthouse http://localhost:3000/?__lh=1 --preset=desktop --chrome-flags='--headless=new --no-sandbox --disable-dev-shm-usage --disable-gpu --disable-software-rasterizer' --only-categories=performance,accessibility,best-practices,seo --output=json --output=html --output-path=./lighthouse-results/home-latest",
    "lighthouse:home:local": "bash -lc 'mkdir -p ./lighthouse-results; npm run start >/tmp/mh-next-start.log 2>&1 & PID=$!; npx wait-on http://localhost:3000; npm run lighthouse:home; STATUS=$?; kill $PID; wait $PID 2>/dev/null || true; exit $STATUS'",
    "lighthouse:home:median": "node scripts/validation/home-lighthouse-median.js",
    "lhci:collect:home": "npx lhci collect --url=http://localhost:3000/?__lh=1 --numberOfRuns=1 --settings.chromeFlags='--headless=new --no-sandbox --disable-dev-shm-usage --disable-gpu --disable-software-rasterizer'",
    "format": "prettier --write --cache --cache-location .prettier-cache .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "pages:dev": "npm run dev",
    "bundle:size": "npm run build && du -sh .next/static/chunks/*.js | sort -hr | head -10",
    "bundle:report": "du -sh .next/static/chunks/*.js 2>/dev/null | sort -hr | head -10 || echo 'No chunks found'",
    "clean": "bash scripts/cleanup/cleanup.sh",
    "maintenance": "npm run clean",
    "lint:markdown": "npm run docs:sync:check && root=$(git rev-parse --show-toplevel) && git ls-files '*.md' ':!:.github/agents/**' ':!:public/images/qr-codes/README.md' ':!:apps/website/public/images/qr-codes/README.md' ':!:apps/website/docs/**' | sed \"s#^#$root/#\" | xargs -r markdownlint-cli2 --config \"$root/.markdownlint-cli2.jsonc\" --ignore-path \"$root/.markdownlintignore\" --no-globs",
    "lint:markdown:fix": "markdownlint-cli2 --fix --config .markdownlint-cli2.jsonc --ignore-path .markdownlintignore \"**/*.md\"",
    "lint:brand": "bash scripts/brand-lint.sh",
    "lint:brand:ci": "BRAND_LINT_CHANGED_ONLY=true BRAND_LINT_BASE_SHA=${BASE_SHA:-} bash scripts/brand-lint.sh",
    "docs:sync": "root=$(git rev-parse --show-toplevel) && bash \"$root/scripts/docs/sync-to-app.sh\"",
    "docs:sync:check": "root=$(git rev-parse --show-toplevel) && bash \"$root/scripts/docs/check-sync.sh\"",
    "check:translations": "node scripts/check-translations.js",
    "cspell:check": "npx cspell \"**/*.{md,js,ts,tsx,json}\" --no-progress --show-context",
    "cspell:add": "bash scripts/utilities/add-cspell-word.sh",
    "cspell:add:names": "bash scripts/utilities/add-cspell-word.sh --dict names",
    "cspell:add:safety": "bash scripts/utilities/add-cspell-word.sh --dict safety",
    "cspell:add:spanish": "bash scripts/utilities/add-cspell-word.sh --dict spanish",
    "cspell:add:tech": "bash scripts/utilities/add-cspell-word.sh --dict tech-additions",
    "cspell:unknown": "bash scripts/utilities/list-cspell-unknown-words.sh",
    "docs:extract": "node documents/scripts/extract.mjs",
    "docs:extract-word": "node documents/scripts/extract-word.mjs",
    "docs:build-public": "node documents/scripts/build-safety-manual-public.mjs",
    "prebuild": "node documents/scripts/build-safety-manual-public.mjs",
    "docs:ocr": "node documents/scripts/ocr-pdf.mjs",
    "docs:generate": "node documents/scripts/generate.mjs",
    "docs:generate:cover": "node documents/scripts/generate.mjs --template cover",
    "docs:generate:spine": "node documents/scripts/generate.mjs --template spine",
    "docs:generate:letterhead": "node documents/scripts/generate.mjs --template letterhead",
    "docs:generate:tabs": "node documents/scripts/generate.mjs --template tabs",
    "docs:generate:sections": "node documents/scripts/generate.mjs --template sections",
    "docs:generate:forms": "node documents/scripts/generate.mjs --template forms",
    "docs:merge": "node documents/scripts/merge.mjs",
    "docs:merge:digital": "node documents/scripts/merge.mjs --no-tabs",
    "docs:publish": "echo '⚠️  PDFs are now served from Cloudflare R2. Use docs:publish:r2 for local uploads.'",
    "docs:publish:r2": "bash scripts/r2-seed-pdfs.sh",
    "docs:publish:safety": "bash scripts/r2-publish-safety-pdfs.sh",
    "docs:publish:forms": "bash scripts/r2-publish-forms.sh",
    "docs:all": "npm run docs:generate && npm run docs:generate:forms && npm run docs:merge && npm run docs:merge:digital",
    "docs:release": "npm run docs:all && npm run docs:publish:safety && npm run docs:publish:forms",
    "rfq:generate": "node documents/scripts/rfq-generate.mjs",
    "rfq:generate:help": "node documents/scripts/rfq-generate.mjs --help",
    "rfq:preview": "node documents/scripts/rfq-preview.mjs",
    "qr:generate": "node scripts/generate-qr-codes.js",
    "qr:test": "node scripts/test-qr-codes.js",
    "qr:check": "bash scripts/check-qr-codes.sh",
    "optimize:images": "node scripts/optimization/optimize-images.js",
    "optimize:videos": "node scripts/optimization/optimize-videos.js",
    "audit:images": "node scripts/optimization/audit-images.js",
    "check:image-sizes": "node scripts/optimization/check-sizes.js",
    "quality:check": "bash scripts/utilities/cleanup-check.sh",
    "deps:check": "npx depcheck --ignores='@types/*,eslint-*,@eslint/*,prettier,husky,@commitlint/*,postcss,autoprefixer,jest-environment-jsdom,@opennextjs/cloudflare,chalk,@cspell/dict-es-es,@tailwindcss/postcss,cross-env,esbuild,lint-staged'",
    "deps:update": "npm outdated",
    "deps:clean": "npm prune && npm dedupe",
    "prepare": "node -e \"const {spawnSync}=require('node:child_process'); const result=spawnSync('git',['rev-parse','--is-inside-work-tree'],{stdio:'ignore'}); if (process.env.CI || result.status !== 0) process.exit(0)\" && husky"
  },
  "keywords": [
    "construction",
    "nextjs",
    "cloudflare",
    "veteran-owned",
    "typescript"
  ],
  "author": "MH Construction Development Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/browser": "^10.50.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "next-intl": "^4.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "toucan-js": "^4.1.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@next/swc-linux-x64-gnu": "16.2.6",
    "@opennextjs/cloudflare": "1.19.4",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "sanitize-html": "^2.17.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "chrome-launcher": "^1.2.1",
    "jsqr": "^1.4.0",
    "lighthouse": "^13.0.3",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}
