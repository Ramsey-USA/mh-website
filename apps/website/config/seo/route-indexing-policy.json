{
  "classes": {
    "indexable": {
      "exact": [
        "/",
        "/about",
        "/accessibility",
        "/allies",
        "/careers",
        "/contact",
        "/cool-desert-nights",
        "/events/[slug]",
        "/faq",
        "/faq/[category]",
        "/jeremy-thamert",
        "/locations",
        "/locations/[city]",
        "/news",
        "/privacy",
        "/projects",
        "/projects/[slug]",
        "/public-sector",
        "/public-sector/tri-state-government-construction",
        "/public-sector/veteran-led-compliance",
        "/resources",
        "/resources/safety-manual/contents",
        "/resources/safety-manual/forms",
        "/safety",
        "/services",
        "/team",
        "/terms",
        "/testimonials",
        "/veterans",
        "/veterans/public-sector-construction"
      ],
      "patterns": [
        "^/resources/safety-manual/\\[cluster\\]$"
      ]
    },
    "noindex": {
      "exact": [
        "/about/details",
        "/careers/print",
        "/employee-handbook",
        "/events",
        "/offline",
        "/qr-codes",
        "/safety/incident-report",
        "/safety/print/[id]",
        "/sitemap"
      ],
      "patterns": []
    },
    "redirect": {
      "exact": [
        "/resources/safety-manual",
        "/resources/safety-manual/section/[slug]",
        "/resources/safety-program",
        "/safety/intake"
      ],
      "patterns": []
    }
  },
  "dynamicSitemapCoverage": [
    {
      "pattern": "^/resources/safety-manual/\\[cluster\\]$",
      "requiresAny": [
        "ALL_CLUSTER_SLUGS",
        "clusterEntries"
      ]
    },
    {
      "pattern": "^/projects/\\[slug\\]$",
      "requiresAny": [
        "getPublishedProjectCaseStudySlugs",
        "projectEntries"
      ]
    },
    {
      "pattern": "^/faq/\\[category\\]$",
      "requiresAny": [
        "getFAQCategorySlugs",
        "faqEntries"
      ]
    },
    {
      "pattern": "^/locations/\\[city\\]$",
      "requiresAny": [
        "getLocationSlugs",
        "locationEntries"
      ]
    },
    {
      "pattern": "^/events/\\[slug\\]$",
      "requiresAny": [
        "eventRecords",
        "eventEntries"
      ]
    }
  ],
  "pendingClassification": []
}
